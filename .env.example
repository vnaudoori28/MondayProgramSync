# Monday.com API token
# Get from: https://monday.com → Profile → Admin → API
MONDAY_API_TOKEN=your_token_here

# Program Tracker board ID
# Get from: Board → three-dot menu → Board info → Board ID
TRACKER_BOARD_ID=your_tracker_board_id

# Sprint Board ID
SPRINT_BOARD_ID=your_sprint_board_id

# Group ID within Sprint Board where tasks should be created
# e.g. the "Programs in Planning and Delivery Phase" group
# Get via: python src/main.py --show-groups (or from Monday board URL)
SPRINT_GROUP_ID=your_sprint_group_id

# Path to folder containing per-program subfolders with program.xlsx
# Default is "programs" (relative to repo root)
PROGRAMS_DIR=programs
